<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Shoge" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/orange_primary</item>
        <item name="colorPrimaryVariant">@color/orange_dark</item>
        <item name="colorOnPrimary">@color/bg_white</item>

        <!-- Secondary / accent -->
        <item name="colorSecondary">@color/orange_light</item>
        <item name="colorOnSecondary">@color/bg_white</item>

        <!-- Surfaces -->
        <item name="android:colorBackground">@color/bg_surface</item>
        <item name="colorSurface">@color/bg_white</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Shapes -->
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Shoge.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Shoge.Large</item>
    </style>

    <!-- Rounded corners -->
    <style name="ShapeAppearance.Shoge.Medium" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeAppearance.Shoge.Large" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>
    <!-- Add inside <resources> in themes.xml -->
    <style name="Theme.Shoge.Transparent" parent="Theme.Shoge">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation</item>
    </style>

    <!-- ── TextInputLayout: outlined with orange focus ── -->
    <style name="Widget.Shoge.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@drawable/selector_input_stroke</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@drawable/selector_hint_color</item>
        <item name="boxBackgroundColor">@color/bg_white</item>
        <item name="android:paddingTop">0dp</item>
    </style>

    <!-- ── Icon toggle buttons ── -->
    <style name="Widget.Shoge.ToggleButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="iconSize">16dp</item>
        <item name="iconPadding">6dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="rippleColor">@color/orange_surface</item>
    </style>

    <!-- ── Circle shape for icon preview / ShapeableImageView ── -->
    <style name="ShapeAppearance.Shoge.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Widget.Shoge.FormDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:layout_marginBottom">20dp</item>
        <item name="android:background">@color/divider</item>
    </style>

</resources>