<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="12dp"
    android:paddingBottom="32dp"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@drawable/shape_bottom_sheet_handle"/>

    <!-- Title row -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pick a Color"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="20dp"/>

    <!-- 4-column swatch grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_color_swatches"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never"/>

    <!-- "or enter hex" divider -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@color/divider"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="or enter hex"
            android:textSize="12sp"
            android:textColor="@color/text_hint"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@color/divider"/>

    </LinearLayout>

    <!-- Hex input + live preview circle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <!-- Live color preview -->
        <View
            android:id="@+id/view_color_preview"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_icon_preview"/>

        <!-- Hex code EditText -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Shoge.TextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_hex_color"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="#FF6B00"
                android:inputType="text"
                android:maxLength="7"
                android:textSize="15sp"
                android:fontFamily="monospace"
                android:textColor="@color/text_primary"/>

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- Done -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_color_done"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="Apply Color"
        android:textColor="@color/bg_white"
        app:backgroundTint="@color/orange_primary"
        app:cornerRadius="@dimen/corner_radius"/>

</LinearLayout>